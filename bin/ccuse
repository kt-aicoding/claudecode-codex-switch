#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
PROFILE_DIR="${PROFILE_DIR:-$CLAUDE_DIR/profiles}"
SETTINGS_FILE="${SETTINGS_FILE:-$CLAUDE_DIR/settings.json}"
BACKUP_SUFFIX="${BACKUP_SUFFIX:-.bak}"

usage() {
  cat <<'USAGE'
Usage:
  ccuse global <name>    Switch global Claude Code settings to a profile
  ccuse session <name>   Run one Claude Code session with a profile, without changing settings
  ccuse run <name>       Alias for session
  ccuse claude          Switch to native Claude profile
  ccuse ark             Switch to Volcengine Ark Coding Plan profile
  ccuse volcengine      Alias for ark
  ccuse glm             Switch to GLM (Zhipu AI) profile
  ccuse kimi            Switch to Kimi (Moonshot AI) profile
  ccuse init-claude     Save current settings.json as claude profile
  ccuse init-ark        Create or reconfigure a Volcengine Ark Coding Plan profile
  ccuse init-volcengine Alias for init-ark
  ccuse init-glm        Create or reconfigure a GLM profile
  ccuse init-kimi       Create or reconfigure a Kimi profile
  ccuse list            List all available profiles
  ccuse show            Show current Claude Code configuration
  ccuse vpn <name> on <proxy-url> [no_proxy]
                         Persist proxy env in a profile for VPN/proxy usage
  ccuse vpn <name> off   Remove proxy env from a profile
  ccuse vpn <name> show  Show proxy env configured in a profile
  ccuse models          List common provider model ids and examples
  ccuse edit <name>     Edit a profile file
  ccuse remove <name>   Remove a profile

Environment overrides:
  CLAUDE_DIR, PROFILE_DIR, SETTINGS_FILE, BACKUP_SUFFIX

Examples:
  ccuse global glm       # Persistently switch Claude Code settings
  ccuse session glm -- --model glm-5
                         # Run one Claude session with GLM env, no settings write
  ccuse session kimi --proxy http://127.0.0.1:7890
                         # Run one session through a VPN/proxy
  ccuse vpn ark on http://127.0.0.1:7890 "localhost,127.0.0.1"
  ccuse init-ark        # Create or reconfigure Ark Coding Plan profile
  ccuse ark             # Switch to Ark Coding Plan profile
  ccuse show            # View current configuration
  ccuse list            # See all available profiles
  ccuse remove ark      # Remove Ark profile
USAGE
}

ensure_profiles_dir() {
  mkdir -p "$PROFILE_DIR"
}

backup_settings() {
  if [[ -f "$SETTINGS_FILE" ]]; then
    cp "$SETTINGS_FILE" "${SETTINGS_FILE}${BACKUP_SUFFIX}"
  fi
}

apply_profile() {
  local name="$1"
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi
  backup_settings
  cp "$file" "$SETTINGS_FILE"
  echo "Switched to profile: $name"
}

profile_env_args() {
  local file="$1"
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for session-level profile env loading." >&2
    exit 1
  fi
  python3 - "$file" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
env = data.get("env", {})
if not isinstance(env, dict):
    raise SystemExit(f"Expected object at env in {path}")
for key, value in env.items():
    print(f"{key}={value}", end="\0")
PY
}

build_proxy_env() {
  local proxy_url="$1"
  local no_proxy="${2:-localhost,127.0.0.1,::1}"
  printf 'HTTP_PROXY=%s\n' "$proxy_url"
  printf 'HTTPS_PROXY=%s\n' "$proxy_url"
  printf 'ALL_PROXY=%s\n' "$proxy_url"
  printf 'http_proxy=%s\n' "$proxy_url"
  printf 'https_proxy=%s\n' "$proxy_url"
  printf 'all_proxy=%s\n' "$proxy_url"
  printf 'NO_PROXY=%s\n' "$no_proxy"
  printf 'no_proxy=%s\n' "$no_proxy"
}

vpn_env_args() {
  local proxy_url=""
  local no_proxy=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --proxy|--vpn)
        proxy_url="${2:-}"
        if [[ -z "$proxy_url" ]]; then
          echo "Missing value for $1" >&2
          exit 1
        fi
        shift 2
        ;;
      --no-proxy)
        no_proxy="${2:-}"
        if [[ -z "$no_proxy" ]]; then
          echo "Missing value for --no-proxy" >&2
          exit 1
        fi
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  if [[ -n "$proxy_url" ]]; then
    build_proxy_env "$proxy_url" "${no_proxy:-localhost,127.0.0.1,::1}" | while IFS= read -r line; do
      printf '%s\0' "$line"
    done
  fi
}

strip_vpn_options() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --proxy|--vpn|--no-proxy)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for $1" >&2
          exit 1
        fi
        shift 2
        ;;
      *)
        printf '%s\0' "$1"
        shift
        ;;
    esac
  done
}

run_profile_session() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse session <profile-name> [--proxy URL] [-- claude args...]" >&2
    exit 1
  fi
  shift || true
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Missing profile file: $file" >&2
    echo "Run: ccuse init-$name" >&2
    exit 1
  fi

  local env_args=()
  local item
  while IFS= read -r -d '' item; do
    env_args+=("$item")
  done < <(profile_env_args "$file")
  while IFS= read -r -d '' item; do
    env_args+=("$item")
  done < <(vpn_env_args "$@")

  local clean_args=()
  while IFS= read -r -d '' item; do
    clean_args+=("$item")
  done < <(strip_vpn_options "$@")

  local claude_args=()
  local seen_dash=false
  for item in "${clean_args[@]}"; do
    if [[ "$item" == "--" && "$seen_dash" == "false" ]]; then
      seen_dash=true
      continue
    fi
    claude_args+=("$item")
  done

  exec env "${env_args[@]}" claude "${claude_args[@]}"
}

profile_proxy() {
  local name="${1:-}"
  local action="${2:-show}"
  local proxy_url="${3:-}"
  local no_proxy="${4:-localhost,127.0.0.1,::1}"
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse vpn <profile-name> on|off|show [proxy-url] [no_proxy]" >&2
    exit 1
  fi
  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Profile not found: $file" >&2
    exit 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for ccuse vpn." >&2
    exit 1
  fi
  case "$action" in
    on)
      if [[ -z "$proxy_url" ]]; then
        echo "Usage: ccuse vpn <profile-name> on <proxy-url> [no_proxy]" >&2
        exit 1
      fi
      python3 - "$file" "$proxy_url" "$no_proxy" <<'PY'
import json
import sys

path, proxy_url, no_proxy = sys.argv[1:4]
with open(path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
env = data.setdefault("env", {})
if not isinstance(env, dict):
    raise SystemExit(f"Expected object at env in {path}")
for key in ("HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "http_proxy", "https_proxy", "all_proxy"):
    env[key] = proxy_url
env["NO_PROXY"] = no_proxy
env["no_proxy"] = no_proxy
with open(path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2, ensure_ascii=False)
    fh.write("\n")
PY
      chmod 600 "$file"
      echo "Proxy env saved in profile: $file"
      ;;
    off)
      python3 - "$file" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
env = data.get("env", {})
if isinstance(env, dict):
    for key in ("HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "http_proxy", "https_proxy", "all_proxy", "NO_PROXY", "no_proxy"):
        env.pop(key, None)
with open(path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2, ensure_ascii=False)
    fh.write("\n")
PY
      echo "Proxy env removed from profile: $file"
      ;;
    show)
      python3 - "$file" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as fh:
    data = json.load(fh)
env = data.get("env", {})
for key in ("HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "NO_PROXY"):
    if isinstance(env, dict) and key in env:
        print(f"{key}=****")
PY
      ;;
    *)
      echo "Usage: ccuse vpn <profile-name> on|off|show" >&2
      exit 1
      ;;
  esac
}

init_claude() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/claude.json"
  if [[ -f "$SETTINGS_FILE" ]]; then
    cp "$SETTINGS_FILE" "$file"
    echo "Saved current settings to: $file"
  else
    printf '{\n}\n' > "$file"
    echo "Created empty profile: $file"
  fi
  echo ""
  echo "This profile uses your native Claude API key from Anthropic."
  echo "No additional configuration needed."
}

init_ark() {
  ensure_profiles_dir
  local file="$PROFILE_DIR/ark.json"
  local backup_file=""

  # If profile exists, ask user what to do
  if [[ -f "$file" ]]; then
    echo "Profile already exists: $file"
    read -rp "Do you want to reconfigure it? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      # Backup existing profile
      backup_file="${file}.bak.$(date +%Y%m%d%H%M%S)"
      cp "$file" "$backup_file"
      echo "Backup created: $backup_file"
      echo ""
    else
      echo "Keeping existing profile. Use 'ccuse edit ark' to modify it."
      exit 0
    fi
  fi

  cat > "$file" <<'JSON'
{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_ARK_API_KEY",
    "ANTHROPIC_BASE_URL": "https://ark.cn-beijing.volces.com/api/coding",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "doubao-seed-2-0-code-preview-260215",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "doubao-seed-2-0-code-preview-260215",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "doubao-seed-2-0-code-preview-260215"
  }
}
JSON
  chmod 600 "$file"
  if [[ -n "$backup_file" ]]; then
    echo "Reconfigured profile: $file"
  else
    echo "Created template: $file"
  fi
  echo ""
  echo "=========================================="
  echo "  Next Step: Set your Volcengine Ark API Key"
  echo "=========================================="
  echo ""
  echo "1. Get your API key from Volcengine Ark Coding Plan."
  echo "2. Replace YOUR_ARK_API_KEY in the profile file."
  echo ""
  echo "Default Coding Plan model:"
  echo "  - doubao-seed-2-0-code-preview-260215"
  echo ""
  echo "3. Then run: ccuse ark"
  echo ""
  edit_file "$file"
}

