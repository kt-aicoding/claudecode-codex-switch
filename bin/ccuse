  ensure_profiles_dir
  local file="$PROFILE_DIR/kimi.json"
  local backup_file=""

  # If profile exists, ask user what to do
  if [[ -f "$file" ]]; then
    echo "Profile already exists: $file"
    read -rp "Do you want to reconfigure it? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      # Backup existing profile
      backup_file="${file}.bak.$(date +%Y%m%d%H%M%S)"
      cp "$file" "$backup_file"
      echo "Backup created: $backup_file"
      echo ""
    else
      echo "Keeping existing profile. Use 'ccuse edit kimi' to modify it."
      exit 0
    fi
  fi

  cat > "$file" <<'JSON'
{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_KIMI_API_KEY",
    "ANTHROPIC_BASE_URL": "https://api.kimi.com/coding/",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "kimi-k2.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k2.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2.5"
  }
