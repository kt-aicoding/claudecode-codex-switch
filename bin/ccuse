  echo "  - GLM-5            (Latest flagship, coding aligned with Claude Opus 4.5)"
  echo "  - GLM-4.7          (High intelligence, better coding & aesthetics)"
  echo "  - GLM-4.7-FlashX   (Lightweight, fast, cost-effective)"
