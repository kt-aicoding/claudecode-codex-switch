edit_file() {
  local file="$1"
  if [[ -n "${EDITOR:-}" ]]; then
    echo "Opening $file with $EDITOR..."
    $EDITOR "$file"
  elif command -v code &>/dev/null; then
    echo "Opening $file with VS Code..."
    code "$file"
  elif command -v nano &>/dev/null; then
    echo "Opening $file with nano..."
    nano "$file"
  else
    echo "File location: $file"
    echo "Please edit it manually."
  fi
}

list_profiles() {
  ensure_profiles_dir
  echo "Available profiles in $PROFILE_DIR:"
  echo ""
  local current=""
  local active_profile=""
  if [[ -f "$SETTINGS_FILE" ]]; then
    current=$(basename "$(readlink -f "$SETTINGS_FILE" 2>/dev/null || echo "$SETTINGS_FILE")" .json 2>/dev/null || echo "")
    # Try to detect active profile by comparing content
    for f in "$PROFILE_DIR"/*.json; do
      if [[ -f "$f" ]]; then
        if diff -q "$SETTINGS_FILE" "$f" >/dev/null 2>&1; then
          active_profile=$(basename "$f" .json)
          break
        fi
      fi
    done
  fi

  local count=0
  for f in "$PROFILE_DIR"/*.json; do
    if [[ -f "$f" ]]; then
      ((count++)) || true
      local name=$(basename "$f" .json)
      if [[ "$name" == "$active_profile" ]]; then
        echo "  * $name (active)"
      else
        echo "    $name"
      fi
    fi
  done

  if [[ $count -eq 0 ]]; then
    echo "  (no profiles found)"
    echo ""
    echo "Run 'ccuse init-<provider>' to create a profile."
  else
    echo ""
    echo "Run 'ccuse <name>' to switch to a profile."
  fi
}

remove_profile() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: ccuse remove <profile-name>" >&2
    exit 1
  fi

  local file="$PROFILE_DIR/$name.json"
  if [[ ! -f "$file" ]]; then
    echo "Profile not found: $file" >&2
    exit 1
  fi

  # Check if this is the currently active profile
  local is_active=false
  if [[ -f "$SETTINGS_FILE" ]] && diff -q "$SETTINGS_FILE" "$file" >/dev/null 2>&1; then
    is_active=true
  fi

  echo "Removing profile: $name"
  if [[ "$is_active" == "true" ]]; then
    echo "Warning: This is your currently active profile!"
  fi
  read -rp "Are you sure? [y/N] " answer
  if [[ "$answer" =~ ^[Yy]$ ]]; then
    rm "$file"
    echo "Profile removed: $name"
    if [[ "$is_active" == "true" ]]; then
      echo ""
      echo "Note: Your current settings.json still uses this configuration."
      echo "Switch to another profile with 'ccuse <name>' to change."
    fi
  else
    echo "Cancelled."
    exit 0
  fi
}

show_config() {
  echo "Current Claude Code Configuration"
  echo "=================================="
  echo ""
  echo "Settings file: $SETTINGS_FILE"
  echo ""
  if [[ ! -f "$SETTINGS_FILE" ]]; then
    echo "No settings file found."
    return
  fi
  echo "Configuration:"
  echo ""
  # Parse and display key environment variables
  if command -v python3 &>/dev/null; then
    python3 -c "
import json
import sys
try:
    with open('$SETTINGS_FILE', 'r') as f:
        data = json.load(f)
    env = data.get('env', {})
    if not env:
        print('  (empty configuration)')
    else:
        # Show key configurations, mask API keys
        for key, value in sorted(env.items()):
            if 'KEY' in key.upper() or 'TOKEN' in key.upper():
                # Mask API key
                if len(str(value)) > 8:
                    masked = str(value)[:4] + '****' + str(value)[-4:]
                else:
                    masked = '****'
                print(f'  {key}: {masked}')
            else:
                print(f'  {key}: {value}')
except Exception as e:
    print(f'  Error reading config: {e}')
    sys.exit(1)
"
  else
    # Fallback: just cat the file
    cat "$SETTINGS_FILE"
  fi
  echo ""
  echo "=================================="
  echo "Run 'ccuse edit' to modify, 'ccuse list' to see profiles."
}

list_models() {
  cat <<'MODELS'
Claude Code native aliases/examples:
  opus                    Claude Code alias for latest Opus-class model
  sonnet                  Claude Code alias for latest Sonnet-class model
  fable                   Claude Code alias for latest Fable-class model
  claude-opus-4-6         Example full model id
  claude-sonnet-4-6       Example full model id
  claude-fable-5          Example full model id shown by Claude Code help

Volcengine Ark Coding Plan:
  doubao-seed-2-0-code-preview-260215

Zhipu GLM Anthropic-compatible examples:
  glm-5
  glm-4.7
  glm-4.7-FlashX

Moonshot Kimi Coding examples:
  kimi-k2.5

Usage:
  Global provider/profile: ccuse global glm
  Session provider/profile: ccuse session glm -- --model glm-5
  Native Claude session model: claude --model sonnet

Notes:
  Provider model ids change. Check the provider console/docs before automating.
MODELS
}

case "${1:-}" in
  global) apply_profile "${2:-}" ;;
  session|run)
    shift
    run_profile_session "$@"
    ;;
  claude) apply_profile "claude" ;;
  ark|volcengine) apply_profile "ark" ;;
  glm) apply_profile "glm" ;;
  kimi) apply_profile "kimi" ;;
  init-claude) init_claude ;;
  init-ark|init-volcengine) init_ark ;;
  init-glm) init_glm ;;
  init-kimi) init_kimi ;;
  list|ls) list_profiles ;;
  vpn|proxy) profile_proxy "${2:-}" "${3:-show}" "${4:-}" "${5:-localhost,127.0.0.1,::1}" ;;
  models) list_models ;;
  remove|rm) remove_profile "${2:-}" ;;
  delete) remove_profile "${2:-}" ;;
  show|config|current) show_config ;;
  edit)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: ccuse edit <profile-name>" >&2
      exit 1
    fi
    file="$PROFILE_DIR/${2}.json"
    if [[ ! -f "$file" ]]; then
      echo "Profile not found: $file" >&2
      exit 1
    fi
    edit_file "$file"
    ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown command: $1" >&2; usage; exit 2 ;;
esac
